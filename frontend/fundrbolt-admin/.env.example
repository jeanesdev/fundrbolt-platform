VITE_CLERK_PUBLISHABLE_KEY=
VITE_API_URL=http://localhost:8000/api/v1
VITE_GOOGLE_MAPS_API_KEY=
VITE_ENABLE_ADDRESS_AUTOCOMPLETE=false

# NPO Onboarding — Cloudflare Turnstile (CAPTCHA)
# Get site key at: https://dash.cloudflare.com/ → Turnstile
# Test site key (always passes): 1x00000000000000000000AA
VITE_TURNSTILE_SITE_KEY=1x00000000000000000000AA

# Multiplier (as a percentage) used to suggest a Buy Now price from the Fair Market Value.
# Default: 250 (i.e. 250% of FMV)
VITE_BUY_NOW_PRICE_MULTIPLIER=250
