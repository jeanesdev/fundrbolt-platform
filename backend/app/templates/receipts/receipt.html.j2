<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Payment Receipt — {{ event_name }}</title>
  <style>
    /* ── Reset ─────────────────────────────────────────────────────────────── */
    * { box-sizing: border-box; }
    body {
      font-family: Arial, Helvetica, sans-serif;
      font-size: 14px;
      color: #1a1a1a;
      line-height: 1.6;
      margin: 0;
      padding: 32px;
      background: #ffffff;
    }
    /* ── Page size (WeasyPrint) ─────────────────────────────────────────────── */
    @page { size: A4; margin: 20mm 15mm; }

    .receipt { max-width: 560px; margin: 0 auto; }

    /* ── Header ─────────────────────────────────────────────────────────────── */
    .receipt-header {
      border-bottom: 2px solid #dddddd;
      padding-bottom: 16px;
      margin-bottom: 24px;
    }
    .receipt-header img { max-height: 64px; margin-bottom: 12px; display: block; }
    .receipt-header h1 { font-size: 22px; margin: 0 0 2px; color: #111; }
    .receipt-header .npo-name { font-size: 14px; color: #555; margin: 0; }

    /* ── Summary ────────────────────────────────────────────────────────────── */
    .receipt-summary { margin-bottom: 24px; }
    .receipt-summary table { width: 100%; border-collapse: collapse; }
    .receipt-summary td { padding: 3px 0; vertical-align: top; }
    .receipt-summary td.label {
      font-weight: 600;
      width: 150px;
      color: #444;
    }

    /* ── Line items ─────────────────────────────────────────────────────────── */
    .line-items { width: 100%; border-collapse: collapse; margin-top: 8px; }
    .line-items th,
    .line-items td { padding: 8px 10px; border-bottom: 1px solid #eeeeee; }
    .line-items th {
      background-color: #f5f5f5;
      font-weight: 600;
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: 0.04em;
      color: #666;
      border-top: 1px solid #dddddd;
    }
    .line-items td.amount,
    .line-items th.amount { text-align: right; width: 110px; }
    .line-items td.type-badge {
      font-size: 11px;
      color: #888;
      width: 90px;
    }
    .line-items tr.total td {
      font-weight: 700;
      font-size: 15px;
      border-top: 2px solid #222;
      border-bottom: none;
      background-color: #fafafa;
    }

    /* ── Footer ─────────────────────────────────────────────────────────────── */
    .receipt-footer {
      border-top: 1px solid #dddddd;
      padding-top: 16px;
      margin-top: 32px;
      font-size: 12px;
      color: #777;
    }
    .receipt-footer p { margin: 4px 0; }
    .receipt-footer a { color: #555; }
    .powered-by { font-size: 10px; color: #aaa; margin-top: 12px; }
  </style>
</head>
<body>
  <div class="receipt">

    <!-- ── Header ─────────────────────────────────────────────────────────── -->
    <div class="receipt-header">
      {% if npo_logo_url %}
        <img src="{{ npo_logo_url }}" alt="{{ npo_name }} logo" />
      {% endif %}
      <h1>Payment Receipt</h1>
      <p class="npo-name">{{ npo_name }}</p>
    </div>

    <!-- ── Summary ────────────────────────────────────────────────────────── -->
    <div class="receipt-summary">
      <table>
        <tr>
          <td class="label">Event</td>
          <td>{{ event_name }}</td>
        </tr>
        <tr>
          <td class="label">Event Date</td>
          <td>{{ event_date }}</td>
        </tr>
        <tr>
          <td class="label">Transaction Date</td>
          <td>{{ transaction_timestamp }}</td>
        </tr>
        <tr>
          <td class="label">Receipt #</td>
          <td>{{ transaction_id }}</td>
        </tr>
        <tr>
          <td class="label">Billed to</td>
          <td>{{ donor_name }}</td>
        </tr>
        {% if card_last4 %}
        <tr>
          <td class="label">Payment Method</td>
          <td>{{ card_brand | upper }} ···· {{ card_last4 }}</td>
        </tr>
        {% endif %}
      </table>
    </div>

    <!-- ── Line items ──────────────────────────────────────────────────────── -->
    <table class="line-items">
      <thead>
        <tr>
          <th>Description</th>
          <th class="type-badge">Type</th>
          <th class="amount">Amount</th>
        </tr>
      </thead>
      <tbody>
        {% for item in line_items %}
        <tr>
          <td>{{ item.label }}</td>
          <td class="type-badge">{{ item.type | replace("_", " ") | title }}</td>
          <td class="amount">${{ "%.2f" | format(item.amount | float) }}</td>
        </tr>
        {% endfor %}
      </tbody>
      <tfoot>
        <tr class="total">
          <td colspan="2">Total Charged</td>
          <td class="amount">${{ "%.2f" | format(total | float) }}</td>
        </tr>
      </tfoot>
    </table>

    <!-- ── Footer ─────────────────────────────────────────────────────────── -->
    <div class="receipt-footer">
      <p>Thank you for your support of <strong>{{ npo_name }}</strong>!</p>
      {% if npo_email %}
      <p>
        Questions? Contact us at <a href="mailto:{{ npo_email }}">{{ npo_email }}</a>.
      </p>
      {% endif %}
      <p class="powered-by">
        This receipt was generated by FundrBolt on behalf of {{ npo_name }}.
        Transaction ID: {{ transaction_id }}
      </p>
    </div>

  </div>
</body>
</html>
