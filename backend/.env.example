# Backend Environment Variables

# Environment
ENVIRONMENT=development
DEBUG=true

# Database (PostgreSQL)
DATABASE_URL=postgresql://fundrbolt_user:fundrbolt_password@localhost:5432/fundrbolt_db

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT Configuration
JWT_SECRET_KEY=your-super-secret-jwt-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Azure Communication Services (Email)
AZURE_COMMUNICATION_CONNECTION_STRING=your-azure-communication-connection-string
EMAIL_FROM_ADDRESS=DoNotReply@fundrbolt.com
EMAIL_FROM_NAME=FundrBolt Platform

# Azure Blob Storage (for NPO logo uploads)
AZURE_STORAGE_CONNECTION_STRING=your-azure-storage-connection-string
AZURE_STORAGE_CONTAINER_NAME=npo-assets
AZURE_STORAGE_ACCOUNT_NAME=fundrboltplatform

# Azure Blob Storage (for branding assets in emails)
# Blob storage URL for fundrbolt logos. Used in email templates for reliable delivery.
# Logos are served directly from Azure Blob Storage 'branding' container with public blob access.
# For production, consider adding Azure CDN for better global performance.
AZURE_CDN_LOGO_BASE_URL=https://fundrboltdevstor.blob.core.windows.net/branding/logos

# Frontend URLs (for email links)
FRONTEND_ADMIN_URL=http://localhost:5173
FRONTEND_DONOR_URL=http://localhost:5174

# Social Authentication
SOCIAL_AUTH_ENABLED=true
SOCIAL_AUTH_ENABLED_PROVIDERS=apple,google,facebook,microsoft
SOCIAL_AUTH_CALLBACK_BASE_URL=http://localhost:8000/api/v1

# Apple OAuth
SOCIAL_AUTH_APPLE_CLIENT_ID=your-apple-client-id
SOCIAL_AUTH_APPLE_CLIENT_SECRET=your-apple-client-secret

# Google OAuth
SOCIAL_AUTH_GOOGLE_CLIENT_ID=your-google-client-id
SOCIAL_AUTH_GOOGLE_CLIENT_SECRET=your-google-client-secret

# Facebook OAuth
SOCIAL_AUTH_FACEBOOK_CLIENT_ID=your-facebook-client-id
SOCIAL_AUTH_FACEBOOK_CLIENT_SECRET=your-facebook-client-secret

# Microsoft OAuth
SOCIAL_AUTH_MICROSOFT_CLIENT_ID=your-microsoft-client-id
SOCIAL_AUTH_MICROSOFT_CLIENT_SECRET=your-microsoft-client-secret

# Super Admin Seed (for initial setup)
SUPER_ADMIN_EMAIL=admin@fundrbolt.com
SUPER_ADMIN_PASSWORD=ChangeMe123!
SUPER_ADMIN_FIRST_NAME=Super
SUPER_ADMIN_LAST_NAME=Admin

# Rate Limiting
RATE_LIMIT_LOGIN_ATTEMPTS=5
RATE_LIMIT_LOGIN_WINDOW_MINUTES=15

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# Security
# Generate a strong secret: python -c "import secrets; print(secrets.token_urlsafe(32))"
# JWT_SECRET_KEY should be at least 32 characters

# Payment Processing (033-payment-processing)
# Set PAYMENT_GATEWAY_BACKEND to "stub" for local dev and "deluxe" for production
PAYMENT_GATEWAY_BACKEND=stub
# Generate encryption key: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CREDENTIAL_ENCRYPTION_KEY=
PAYMENT_PROCESSING_FEE_PCT=0.029
PAYMENT_PROCESSING_FEE_FLAT_CENTS=30
PAYMENT_WEBHOOK_TIMEOUT_MINUTES=5
PAYMENT_PENDING_EXPIRY_HOURS=24
RECEIPTS_BLOB_CONTAINER=payment-receipts
# STUB only: base URL for the in-process stub HPF page
STUB_HPF_BASE_URL=http://localhost:8000
# Celery broker (defaults to REDIS_URL on db 1 if not set)
CELERY_BROKER_URL=redis://localhost:6379/1
